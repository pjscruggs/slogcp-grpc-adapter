{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:semverAllWeekly",
    ":gomod",
    ":noUnscheduledUpdates",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/Chicago",
  "platformAutomerge": false,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "security:floor", "renovate:type-security-floor"],
    "vulnerabilityFixStrategy": "lowest",
    "automerge": true
  },
  "osvVulnerabilityAlerts": true,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update go install tool pins used by GitHub Actions workflows",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+go install \\S+@(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Keep the adapter root module pinned to the lowest supported Go patch release",
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "matchDepTypes": ["golang"],
      "matchDepNames": ["go"],
      "matchFileNames": ["go.mod"],
      "allowedVersions": "/^{{major}}\\.{{minor}}\\.0$/"
    },
    {
      "description": "CI-only dependency updates stay under .github",
      "matchManagers": ["github-actions", "custom.regex"],
      "matchFileNames": [".github/**"],
      "groupName": "adapter ci-only dependencies",
      "labels": ["renovate:ci", "dependency-scope:ci"],
      "schedule": ["* 2 * * *"],
      "prPriority": 20
    },
    {
      "description": "Do not propose routine root go.mod dependency floor updates",
      "matchManagers": ["gomod"],
      "matchFileNames": ["go.mod"],
      "matchDatasources": ["go"],
      "matchDepTypes": ["require"],
      "enabled": false
    },
    {
      "description": "Security floor updates must not wait for normal root Dependency Dashboard approval",
      "matchManagers": ["gomod"],
      "matchFileNames": ["go.mod"],
      "matchJsonata": ["$exists(vulnerabilityFixVersion)"],
      "enabled": true,
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": ["security", "security:floor", "renovate:type-security-floor"]
    },
    {
      "description": "Keep the root go.mod toolchain directive on the latest released Go toolchain",
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "matchDepTypes": ["toolchain"],
      "matchDepNames": ["go"],
      "matchFileNames": ["go.mod"],
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr",
      "groupName": "root go toolchain",
      "labels": ["renovate:toolchain", "dependency-scope:toolchain"],
      "prPriority": 15
    },
    {
      "description": "Keep checked-in example module go directives on the latest released Go version",
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "matchDepTypes": ["golang"],
      "matchDepNames": ["go"],
      "matchFileNames": [".examples/**/go.mod"],
      "rangeStrategy": "bump",
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr",
      "groupName": "examples go directives",
      "labels": ["renovate:examples", "dependency-scope:examples", "renovate:go-version"],
      "prPriority": 6
    },
    {
      "description": "Routine latest-compatible updates for checked-in example modules",
      "matchManagers": ["gomod"],
      "matchFileNames": [".examples/**"],
      "groupName": "examples module dependencies",
      "labels": ["renovate:examples", "dependency-scope:examples"],
      "schedule": ["* 3-6 * * *"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "prPriority": 5
    },
    {
      "description": "Do not update the local unpublished adapter requirement used by examples",
      "matchManagers": ["gomod"],
      "matchFileNames": [".examples/**"],
      "matchPackageNames": ["github.com/pjscruggs/slogcp-grpc-adapter"],
      "enabled": false
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10
}
